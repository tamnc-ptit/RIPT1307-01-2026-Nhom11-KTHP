{
  "extends": "./src/.umi/tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0", 
    "moduleResolution": "bundler", // Hoặc "bundler" nếu bạn dùng Vite/Webpack mới
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@@/*": ["src/.umi/*"],
      "@admin/*": ["src/roles/admin/*"],
      "@gv/*": ["src/roles/lecturer/*"],
      "@sv/*": ["src/roles/student/*"],
    }
  }
}